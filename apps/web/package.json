{
  "name": "@bunker46/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:security": "eslint . --config eslint.security.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:screenshots": "playwright test e2e/screenshots.spec.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bunker46/shared-types": "workspace:*",
    "@lucide/vue": "^1.21.0",
    "@nanostores/vue": "^1.1.0",
    "@noble/hashes": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@vueuse/core": "^14.3.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "localforage": "^1.10.0",
    "nanostores": "^1.3.0",
    "nostr-tools": "^2.23.8",
    "qrcode": "^1.5.4",
    "reka-ui": "^2.10.0",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@bunker46/eslint-config": "workspace:*",
    "@bunker46/tsconfig": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.1",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
