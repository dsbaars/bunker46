# Database
DATABASE_URL=postgresql://bunker46:bunker46@localhost:5432/bunker46

# JWT
# These are DEV placeholders. In production (NODE_ENV=production) the server refuses to start
# with placeholder/low-entropy secrets. Generate strong values, e.g.: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-random-string-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (AES-256-GCM key, 32+ chars). DEV placeholder — generate a strong key in production:
# openssl rand -base64 48
ENCRYPTION_KEY=change-me-to-a-secure-encryption-key-min-32

# Server
PORT=3000
# Bind address. 0.0.0.0 is fine when only a reverse proxy can reach the container; bind to 127.0.0.1
# if the process is directly reachable and you front it with a proxy on the same host.
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug
# Set to true/1/yes when behind a reverse proxy (e.g. Caddy) so client IP is read from X-Forwarded-For
# TRUST_PROXY=true

# Refresh-cookie Secure flag. Defaults to true when NODE_ENV=production. A Secure cookie is dropped by
# the browser over plain HTTP on a non-localhost host, which logs users out on every page reload (the
# reload restores the session only by exchanging this cookie). If you serve the app over plain HTTP on
# a trusted network (e.g. a LAN-only http://host:port), set this to false. Prefer HTTPS where possible.
# COOKIE_SECURE=false

# CORS (comma-separated origins; keep strict — do not use * with credentials)
CORS_ORIGINS=http://localhost:5173

# WebAuthn / Passkeys
WEBAUTHN_RP_NAME=Bunker46
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# Registration (set to false or 0 to disable new user sign-ups)
# ALLOW_REGISTRATION=false

# Optional notice on login/register page (e.g. "This is a testing server. Do not use real keypairs.")
# LOGIN_NOTICE=This is a testing server. Do not use real keypairs. Data may be deleted at any time.

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# Nostr bunker: override default relays when none are configured in the app (comma-separated wss:// only)
# NOSTR_DEFAULT_RELAYS=wss://relay.nsec.app,wss://relay.damus.io
